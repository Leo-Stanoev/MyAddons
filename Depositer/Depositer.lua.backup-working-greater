function Depositer:OpenSettings()
    if Settings and Settings.OpenToCategory then
        if Depositer_SettingsCategory then Settings.OpenToCategory(Depositer_SettingsCategory.ID) end
    else
        InterfaceOptionsFrame_OpenToCategory("Depositer")
        InterfaceOptionsFrame_OpenToCategory("Depositer")
    end
end

function Depositer:SetupOptions()
    local panel = CreateFrame("Frame", "DepositerOptionsPanel", UIParent)
    panel.name = "Depositer"
    local title = panel:CreateFontString(nil, "ARTWORK", "GameFontNormalLarge")
    title:SetPoint("TOPLEFT", 16, -16)
    title:SetText("Depositer Settings")

    local function CreateToggle(key, label, yOffset)
        local cb = CreateFrame("CheckButton", nil, panel, "InterfaceOptionsCheckButtonTemplate")
        cb:SetPoint("TOPLEFT", 16, yOffset)
        cb.Text:SetText(label)
        cb:SetChecked(GetCfg(key))
        cb:SetScript("OnClick", function(self) DepositerDB[key] = self:GetChecked() end)
        return cb
    end

    CreateToggle("enable_StackSplitter", "Enable Scroll-Wheel Splitting & Auto-Drop", -50)
    
    local div = panel:CreateTexture(nil, "ARTWORK")
    div:SetColorTexture(1, 0.82, 0, 0.35)
    div:SetPoint("TOPLEFT",  panel, "TOPLEFT",  16, -85)
    div:SetPoint("TOPRIGHT", panel, "TOPRIGHT", -16, -85)
    div:SetHeight(1)

    CreateToggle("type_Weapon",    "Deposit Weapons", -100)
    CreateToggle("type_Armor",     "Deposit Armor", -130)
    CreateToggle("type_Consumable", "Deposit Consumables", -160)
    CreateToggle("type_Tradeskill", "Deposit Tradeskill Materials", -190)
    CreateToggle("type_Recipe",    "Deposit Recipes", -220)
    CreateToggle("type_Quest",     "Deposit Quest Items", -250)
    CreateToggle("type_Misc",      "Deposit Miscellaneous", -280)

    if Settings and Settings.RegisterCanvasLayoutCategory then
        local category = Settings.RegisterCanvasLayoutCategory(panel, panel.name)
        category.ID = panel.name
        Settings.RegisterAddOnCategory(category)
        Depositer_SettingsCategory = category
    else
        InterfaceOptions_AddCategory(panel)
    end
end

-- ============================================================================
-- UI Construction & Initialization
-- ============================================================================

function Depositer:CreateButtons()
    if self.btnDeposit then return end

    local dep = CreateFrame("Button", nil, BankFrame, "UIPanelButtonTemplate")
    dep:SetSize(70, 22)
    dep:SetText("Deposit")
    dep:SetPoint("TOPRIGHT", BankFrame, "TOPRIGHT", -25, -14)
    dep:RegisterForClicks("LeftButtonUp", "RightButtonUp")
    
    dep:SetScript("OnClick", function(_, button)
        if button == "RightButton" and IsControlKeyDown() then self:OpenSettings()
        else self:RunDeposit() end
    end)
    
    dep:SetScript("OnEnter", function(s)
        GameTooltip:SetOwner(s, "ANCHOR_RIGHT")
        GameTooltip:AddLine("Depositer", 1, 0.82, 0)
        GameTooltip:AddLine("Left-Click: Deposit matching items", 1, 1, 1)
        GameTooltip:AddLine("Ctrl + Right-Click: Settings", 1, 1, 1)
        GameTooltip:Show()
    end)
    dep:SetScript("OnLeave", function() GameTooltip:Hide() end)
    self.btnDeposit = dep

    local comp = CreateFrame("Button", nil, BankFrame, "UIPanelButtonTemplate")
    comp:SetSize(80, 22)
    comp:SetText("Compress")
    comp:SetPoint("RIGHT", dep, "LEFT", -2, 0)
    comp:SetScript("OnClick", function() self:RunCompress() end)
    
    comp:SetScript("OnEnter", function(s)
        GameTooltip:SetOwner(s, "ANCHOR_RIGHT")
        GameTooltip:AddLine("Stack Compressor", 1, 0.82, 0)
        GameTooltip:AddLine("Merges partial item stacks in both your bank and bags.", 1, 1, 1)
        GameTooltip:Show()
    end)
    comp:SetScript("OnLeave", function() GameTooltip:Hide() end)
    self.btnCompress = comp

    local sort = CreateFrame("Button", nil, BankFrame, "UIPanelButtonTemplate")
    sort:SetSize(60, 22)
    sort:SetText("Sort")
    sort:SetPoint("RIGHT", comp, "LEFT", -2, 0)
    sort:SetScript("OnClick", function() self:RunSort() end)
    
    sort:SetScript("OnEnter", function(s)
        GameTooltip:SetOwner(s, "ANCHOR_RIGHT")
        GameTooltip:AddLine("Bank Sorter", 1, 0.82, 0)
        GameTooltip:AddLine("Sorts the bank by Type, Quality, and Name.", 1, 1, 1)
        GameTooltip:Show()
    end)
    sort:SetScript("OnLeave", function() GameTooltip:Hide() end)
    self.btnSort = sort
end

Depositer:RegisterEvent("ADDON_LOADED")
Depositer:RegisterEvent("BANKFRAME_OPENED")
Depositer:SetScript("OnEvent", function(self, event, arg1)
    if event == "ADDON_LOADED" and arg1 == ADDON_NAME then
        DepositerDB = DepositerDB or {}
        DepositerDB.ignoreList = DepositerDB.ignoreList or {}
        for k, v in pairs(DEFAULT_SETTINGS) do if DepositerDB[k] == nil then DepositerDB[k] = v end end
        
        self:SetupOptions()
        HookStackSplitter()
        
        -- Hook tooltips to show the Ignored tag
        GameTooltip:HookScript("OnTooltipSetItem", OnTooltipSetItem)
        ItemRefTooltip:HookScript("OnTooltipSetItem", OnTooltipSetItem)
        
        -- Dynamically hook click events to support Alt+Right Click on bags
        if ContainerFrameItemButton_OnClick then
            hooksecurefunc("ContainerFrameItemButton_OnClick", HandleAltRightClick)
        end
        if ContainerFrameItemButton_OnModifiedClick then
            hooksecurefunc("ContainerFrameItemButton_OnModifiedClick", HandleAltRightClick)
        end
        -- Baggins specific hook
        if BagginsItemButton_OnClick then
            hooksecurefunc("BagginsItemButton_OnClick", HandleAltRightClick)
        end
        
    elseif event == "BANKFRAME_OPENED" then
        self:CreateButtons()
    end
end)